model MonitorRegion {
  monitorId String @map("monitor_id") @db.Uuid
  regionId  String @map("region_id") @db.Uuid

  lastCheckedAt DateTime?  @map("last_checked_at")
  nextCheckAt   DateTime   @default(now()) @map("next_check_at")
  lastStatus    SiteStatus @default(UNKNOWN) @map("last_status")

  isActive Boolean @default(true) @map("is_active")
  isQueued Boolean @default(false) @map("is_queued")

  logs      MonitorLog[]
  stats     MonitorStats[]
  incidents MonitorIncident[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([monitorId, regionId])
  @@map("monitor_regions")
}
