model GlobalNotification {
  id String @id @default(uuid()) @db.Uuid

  type NotificationType

  isAppNotification   Boolean @default(false) @map("is_app_notification")
  isEmailNotification Boolean @default(false) @map("is_email_notification")

  title     String
  message   String
  actionUrl String? @map("action_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  globalNotificationReads GlobalNotificationRead[]

  @@map("global_notifications")
}
