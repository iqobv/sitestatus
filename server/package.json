{
	"name": "server",
	"version": "1.0.0",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prisma:migrate:pg": "prisma migrate dev --config ./prisma/postgres/prisma.config.ts",
		"prisma:migrate:turso": "prisma migrate dev --config ./prisma/turso/prisma.config.ts",
		"prisma:generate:pg": "prisma generate --config ./prisma/postgres/prisma.config.ts",
		"prisma:push:turso": "prisma db push --config ./prisma/turso/prisma.config.ts",
		"prisma:generate:turso": "prisma generate --config ./prisma/turso/prisma.config.ts",
		"prisma:generate": "npm run prisma:generate:pg && npm run prisma:generate:turso",
		"prisma:studio:pg": "prisma studio --config ./prisma/postgres/prisma.config.ts",
		"prisma:studio:turso": "prisma studio --config ./prisma/turso/prisma.config.ts",
		"prisma:migrate:deploy:pg": "prisma migrate deploy --config ./prisma/postgres/prisma.config.ts",
		"prisma:migrate:deploy:turso": "prisma migrate deploy --config ./prisma/turso/prisma.config.ts"
	},
	"dependencies": {
		"@azure/service-bus": "^7.9.5",
		"@libsql/client": "^0.17.2",
		"@nestjs/axios": "^4.0.1",
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/common": "^11.1.18",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.18",
		"@nestjs/event-emitter": "^3.0.1",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.18",
		"@nestjs/schedule": "^6.1.1",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/throttler": "^6.5.0",
		"@prisma/adapter-libsql": "^7.7.0",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"@react-email/components": "^1.0.11",
		"@react-email/html": "^0.0.12",
		"axios": "^1.14.0",
		"bcryptjs": "^3.0.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.1",
		"express-basic-auth": "^1.2.1",
		"express-session": "^1.19.0",
		"google-auth-library": "^10.6.2",
		"helmet": "^8.1.0",
		"ms": "^2.1.3",
		"nodemailer": "^8.0.4",
		"passport": "^0.7.0",
		"passport-github2": "^0.1.12",
		"passport-google-oauth20": "^2.0.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.20.0",
		"prisma": "^7.6.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@nestjs/cli": "^11.0.17",
		"@nestjs/schematics": "^11.0.10",
		"@nestjs/testing": "^11.1.18",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.24",
		"@types/bcrypt": "^6.0.0",
		"@types/bcryptjs": "^3.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.18.2",
		"@types/jest": "^30.0.0",
		"@types/ms": "^2.1.0",
		"@types/node": "^25.5.2",
		"@types/nodemailer": "^8.0.0",
		"@types/passport": "^1.0.17",
		"@types/passport-github2": "^1.2.9",
		"@types/passport-google-oauth20": "^2.0.17",
		"@types/passport-jwt": "^4.0.1",
		"@types/react": "^19.2.14",
		"@types/supertest": "^7.2.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.4.0",
		"jest": "^30.3.0",
		"prettier": "^3.8.1",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.9",
		"ts-loader": "^9.5.7",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0"
	},
	"overrides": {
		"brace-expansion": "^1.1.13",
		"lodash": "^4.17.24",
		"path-to-regexp": "^8.3.1",
		"picomatch": "^4.0.4",
		"@hono/node-server": "1.19.13"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"moduleNameMapper": {
			"^src/(.*)$": "<rootDir>/src/$1",
			"^generated/(.*)$": "<rootDir>/generated/$1",
			"^(\\.{1,2}/.*)\\.js$": "$1"
		},
		"testEnvironment": "node"
	}
}
