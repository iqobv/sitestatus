{
	"version": "2.0",
	"logging": {
		"logLevel": {
			"default": "Error",
			"Function": "Error",
			"Host": "Error",
			"Host.Results": "Error",
			"Host.Aggregator": "Error"
		},
		"applicationInsights": {
			"samplingSettings": {
				"isEnabled": true,
				"excludedTypes": "Request"
			}
		}
	},
	"extensionBundle": {
		"id": "Microsoft.Azure.Functions.ExtensionBundle",
		"version": "[4.*, 5.0.0)"
	}
}
