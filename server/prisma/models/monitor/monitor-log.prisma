model MonitorLog {
  id BigInt @id @default(autoincrement())

  monitorId String @map("monitor_id") @db.Uuid
  regionId  String @map("region_id") @db.Uuid

  status SiteStatus @default(UNKNOWN)

  statusCode     Int?    @map("status_code") @db.SmallInt
  responseTimeMs Int     @map("response_time_ms") @db.Integer
  errorMessage   String? @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  regionConfig MonitorRegion @relation(fields: [monitorId, regionId], references: [monitorId, regionId], onDelete: Cascade)

  @@index([monitorId, createdAt])
  @@map("monitor_logs")
}
