model GlobalNotificationRead {
  id String @id @default(uuid()) @db.Uuid

  globalNotificationId String @map("global_notification_id") @db.Uuid
  userId               String @map("user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  globalNotification GlobalNotification @relation(fields: [globalNotificationId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([globalNotificationId, userId])
  @@map("global_notification_reads")
}
