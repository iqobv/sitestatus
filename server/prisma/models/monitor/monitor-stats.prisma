model MonitorStats {
  id String @id @default(uuid()) @db.Uuid

  monitorId String @map("monitor_id") @db.Uuid
  regionId  String @map("region_id") @db.Uuid

  status SiteStatus @default(UNKNOWN)

  avgResponseMs Int      @map("avg_response_ms")
  uptimePercent Float    @map("uptime_percent")
  timestamp     DateTime
  p95ResponseMs Int      @default(0) @map("p95_response_ms")

  totalChecks      Int @default(0) @map("total_checks")
  successfulChecks Int @default(0) @map("successfull_checks")

  period StatPeriod

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  regionConfig MonitorRegion @relation(fields: [monitorId, regionId], references: [monitorId, regionId], onDelete: Cascade)

  @@index([monitorId, timestamp])
  @@map("monitor_stats")
}
